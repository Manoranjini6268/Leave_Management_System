# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ────────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/leave_management
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/leave_management
MONGO_URI=mongodb://localhost:27017/leave_management

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRE=30d

# ─── CORS ───────────────────────────────────────────────────────────────────────
# URL of the React dev server (or your deployed frontend)
CLIENT_URL=http://localhost:3000
